
model User {
    id  String  @id @default(uuid())
    name String @db.VarChar(255)
    email String @unique 
    password String
    active_status ActiveStatus @default(ACTIVE)
    role Role @default(USER)
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt
    profile Profile? 

    @@map("users")
}

enum ActiveStatus {
    ACTIVE
    BLOCKED
}

enum Role {
    USER
    AUTHOR
    ADMIN
}